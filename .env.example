# LiquidCode macOS release options
# Copy this file to .env for local release builds. .env is ignored by git.

# Development default: scripts/build-release.sh can produce a local DMG with ad-hoc signing
# when CODESIGN_IDENTITY is unset. Release hard gate: set RELEASE_SIGNING_REQUIRED=1
# to require both Developer ID signing and notarization variables before any build starts.
RELEASE_SIGNING_REQUIRED=0

# Universal build strategy. Default is a universal macOS archive.
# Use "arm64" for a faster local smoke build when you do not need a distributable universal DMG.
LIQUIDCODE_ARCHS="arm64 x86_64"

# Developer ID signing. Required when RELEASE_SIGNING_REQUIRED=1.
# CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Notary profile created with:
#   xcrun notarytool store-credentials LiquidCodeNotary --apple-id <email> --team-id <TEAMID> --password <app-specific-password>
# Required when RELEASE_SIGNING_REQUIRED=1. If set without CODESIGN_IDENTITY, build-release.sh fails.
# NOTARY_KEYCHAIN_PROFILE="LiquidCodeNotary"

# Tauri-compatible updater signing. Release hard gate requires one of these when
# RELEASE_SIGNING_REQUIRED=1. Local dev builds without a key emit a clearly marked
# deterministic dev-only .sig so updater metadata paths can be smoke-tested.
# Prefer a file path for local builds; CI may use secret contents directly.
# UPDATER_SIGNING_PRIVATE_KEY_PATH="$HOME/.tauri/liquidcode.key"
# UPDATER_SIGNING_PRIVATE_KEY="paste-tauri-minisign-private-key-or-path"
# UPDATER_SIGNING_PRIVATE_KEY_PASSWORD="your-passphrase"

# Backward-compatible Tauri env names accepted by scripts/build-release.sh:
# TAURI_SIGNING_PRIVATE_KEY, TAURI_SIGNING_PRIVATE_KEY_PATH, TAURI_SIGNING_PRIVATE_KEY_PASSWORD.

# GitHub release upload controls. RELEASE_UPLOAD_DRY_RUN=1 validates and lists
# artifacts without requiring gh/auth. RELEASE_UPLOAD=1 with dry-run disabled
# hard-fails if RELEASE_TAG/GitHub auth/upload prerequisites are missing.
RELEASE_UPLOAD_DRY_RUN=0
RELEASE_UPLOAD=0
RELEASE_TAG="v0.1.0"
# Optional path to a preinstalled Tauri CLI binary for updater signing.
# TAURI_CLI="/path/to/tauri"

# ---------------------------------------------------------------------------
# CI secrets (GitHub Actions → Settings → Secrets and variables → Actions)
# Used by .github/workflows/release.yml. Leave empty for unsigned CI artifacts.
# ---------------------------------------------------------------------------
# APPLE_CERTIFICATE=base64-encoded-developer-id-application-p12
# APPLE_CERTIFICATE_PASSWORD=p12-password
# KEYCHAIN_PASSWORD=optional-temp-keychain-password
# CODESIGN_IDENTITY=Developer ID Application: Your Name (TEAMID)
# APPLE_ID=you@example.com
# APPLE_PASSWORD=app-specific-password
# APPLE_TEAM_ID=TEAMID
# TAURI_SIGNING_PRIVATE_KEY=minisign-private-key-contents
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=optional-passphrase
