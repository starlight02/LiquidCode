# LiquidCode macOS PKG release options
# Copy to .env for local builds (.env is gitignored).
#
# Version source of truth is Xcode MARKETING_VERSION / CURRENT_PROJECT_VERSION
# in LiquidCode.xcodeproj (also exposed as CFBundleShortVersionString / CFBundleVersion).
# Do not hand-maintain a version here. Use:
#   ./scripts/verify-version.sh
#   ./scripts/cut-release.sh --dry-run

# 0 = ad-hoc / unsigned PKG for local smoke
# 1 = require Developer ID Application + Installer + notary profile
RELEASE_SIGNING_REQUIRED=0

# Default universal; use "arm64" for faster local smoke.
LIQUIDCODE_ARCHS="arm64 x86_64"

# App signing (Developer ID Application). Required when RELEASE_SIGNING_REQUIRED=1.
# CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Installer signing (Developer ID Installer). Required when RELEASE_SIGNING_REQUIRED=1.
# INSTALLER_SIGN_IDENTITY="Developer ID Installer: Your Name (TEAMID)"

# Notary profile:
#   xcrun notarytool store-credentials LiquidCodeNotary --apple-id <email> --team-id <TEAMID> --password <app-specific-password>
# NOTARY_KEYCHAIN_PROFILE="LiquidCodeNotary"

# Optional GitHub upload (build-release.sh).
# Tag defaults to v${MARKETING_VERSION} from the Xcode project.
# Only set RELEASE_TAG to override (must still match MARKETING_VERSION).
RELEASE_UPLOAD_DRY_RUN=0
RELEASE_UPLOAD=0
# RELEASE_TAG=

# ---------------------------------------------------------------------------
# GitHub Actions secrets (Settings → Secrets and variables → Actions)
# ---------------------------------------------------------------------------
# APPLE_CERTIFICATE=base64-encoded-developer-id-application-p12
# APPLE_CERTIFICATE_PASSWORD=p12-password
# KEYCHAIN_PASSWORD=optional-temp-keychain-password
# CODESIGN_IDENTITY=Developer ID Application: Your Name (TEAMID)
# INSTALLER_SIGN_IDENTITY=Developer ID Installer: Your Name (TEAMID)
# APPLE_ID=you@example.com
# APPLE_PASSWORD=app-specific-password
# APPLE_TEAM_ID=TEAMID
# RELEASE_BOT_TOKEN=  # optional PAT so cut-release tag push can trigger Release

